---
/* Why Motiva — six value props in a bento-ish grid. */
import SectionHeader from "@components/SectionHeader.astro"
import { valueProps } from "@data/content"
---

<section class="section bg-bg-soft/50">
  <div class="container-x">
    <SectionHeader
      eyebrow="چرا موتیوا؟"
      title="چیزی که ما را متفاوت می‌کند"
      subtitle="ویدیوساز زیاد است؛ اما چند نفرشان قبل از دکمهٔ ضبط، به فروش شما فکر می‌کنند؟"
    />

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        valueProps.map((v, i) => (
          <article class="card card-hover reveal p-7" data-reveal-delay={i * 70}>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-gradient-soft text-brand-orange">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true">
                <path d={v.icon} />
              </svg>
            </span>
            <h3 class="mt-4 text-lg font-bold">{v.title}</h3>
            <p class="mt-2 leading-8 text-fg-muted">{v.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
