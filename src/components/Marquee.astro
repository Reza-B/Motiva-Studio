---
/* =============================================================
   Industries marquee — an honest "who we shoot for" strip
   (به‌جای لوگوی مشتریان فرضی). CSS-only infinite loop.
   ============================================================= */
import { industries } from "@data/site"

// Duplicate the list so translateX(50%) loops seamlessly.
const loop = [...industries, ...industries]
---

<section class="section-sm border-y border-border bg-bg-soft/60" aria-label="حوزه‌هایی که برایشان ویدیو می‌سازیم">
  <div class="mask-x overflow-hidden" dir="ltr">
    <div class="flex w-max animate-marquee items-center gap-4 pe-4 hover:[animation-play-state:paused]" dir="rtl">
      {
        loop.map((name) => (
          <span class="inline-flex shrink-0 items-center gap-3 rounded-full border border-border bg-surface px-6 py-2.5 text-sm font-medium text-fg-muted">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-gradient" aria-hidden="true" />
            {name}
          </span>
        ))
      }
    </div>
  </div>
</section>
