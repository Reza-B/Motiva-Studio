---
/* =============================================================
   Services grid — gradient-border cards with icon, copy and
   feature list. Used on home (with header) and services page.
   ============================================================= */
import SectionHeader from "@components/SectionHeader.astro"
import { services } from "@data/content"

interface Props {
  showHeader?: boolean
}
const { showHeader = true } = Astro.props
---

<section class="section">
  <div class="container-x">
    {
      showHeader && (
        <SectionHeader
          eyebrow="خدمات ما"
          title="هر قالبی از ویدیو که برندتان لازم دارد"
          subtitle="از ریلز ۱۵ ثانیه‌ای تا فیلم برند سینمایی؛ فرمت را بر اساس هدف شما انتخاب می‌کنیم، نه برعکس."
        />
      )
    }

    <div class:list={["grid gap-5 sm:grid-cols-2 lg:grid-cols-4", showHeader ? "mt-14" : "mt-4"]}>
      {
        services.map((s, i) => (
          <article
            id={s.id}
            class="card-gradient reveal group flex flex-col rounded-[1.75rem] p-7"
            data-reveal-delay={i * 90}
          >
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-gradient-soft text-brand-pink transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
              <svg viewBox="0 0 24 24" class="h-7 w-7" fill="currentColor" aria-hidden="true">
                <path d={s.icon} />
              </svg>
            </span>
            <h3 class="mt-5 text-xl font-bold">{s.title}</h3>
            <p class="mt-3 flex-1 leading-8 text-fg-muted">{s.description}</p>
            <ul class="mt-5 space-y-2 border-t border-border pt-5 text-sm text-fg-muted">
              {s.features.map((f) => (
                <li class="flex items-center gap-2">
                  <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0 text-brand-pink" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m5 13 4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
