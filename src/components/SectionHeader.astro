---
/* Small reusable section heading with eyebrow + title + subtitle. */
interface Props {
  eyebrow?: string
  title: string
  subtitle?: string
  center?: boolean
}
const { eyebrow, title, subtitle, center = true } = Astro.props
---

<div class:list={["reveal max-w-2xl", center && "mx-auto text-center"]}>
  {eyebrow && (
    <span class="eyebrow mb-4">
      <span class="h-2 w-2 rounded-full bg-brand-gradient"></span>
      {eyebrow}
    </span>
  )}
  <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {subtitle && <p class="mt-4 text-lg text-fg-muted">{subtitle}</p>}
</div>
