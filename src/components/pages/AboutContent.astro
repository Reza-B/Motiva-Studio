---
import GradientBlobs from "@components/GradientBlobs.astro";
import StatsCounter from "@components/StatsCounter.astro";
import CTA from "@components/CTA.astro";
---

<section class="section relative overflow-hidden">
	<GradientBlobs />
	<div class="container-x">
		<div class="reveal max-w-3xl">
			<span class="eyebrow mb-4">
				<span
					class="h-2 w-2 rounded-full bg-brand-gradient"
					aria-hidden="true"
				></span>
				دربارهٔ ما
			</span>
			<h1
				class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl"
			>
				قصه‌ها را <span class="text-gradient-animated">به حرکت</span> درمی‌آوریم
			</h1>
			<p class="mt-6 text-xl leading-9 text-fg-muted">
				موتیوا یک استودیوی ساخت ویدیوی تبلیغاتی است؛ جایی که ایدهٔ خام، قاب به
				قاب تبدیل به ویدیویی می‌شود که دیده می‌شود، یادتان می‌ماند و می‌فروشد.
			</p>
			<div class="mt-6 space-y-5 text-lg leading-9 text-fg-muted">
				<p>
					موتیوا از یک مشاهدهٔ ساده شروع شد: کسب‌وکارهای خوب زیادند، اما
					ویدیوهایی که حقشان را ادا کند کم‌اند. خیلی از برندها محصول درجه‌یک
					دارند و تصویری درجه‌سه. ما آمدیم همین فاصله را پر کنیم.
				</p>
				<p>
					تیم ما ترکیبی از کارگردان، تدوینگر، انیمیشن‌ساز و استراتژیست محتواست.
					کنار کافه‌ها، فروشگاه‌های آنلاین، کلینیک‌ها و استارتاپ‌ها نشسته‌ایم و
					از نزدیک دیده‌ایم که یک ویدیوی درست، چطور مسیر یک کسب‌وکار را عوض
					می‌کند. برای همین ذهنمان فقط دنبال قاب زیبا نیست؛ دنبال نتیجه است.
				</p>
				<p>
					از اولین جلسهٔ ایده‌پردازی تا لحظهٔ انتشار، کنار شما می‌مانیم تا پیام
					برندتان دقیقاً همان‌طور که باید، روایت شود — حرفه‌ای، سر وقت و بدون
					دردسر.
				</p>
			</div>
		</div>

		{/* Mission */}
		<div class="card-gradient reveal mt-12 max-w-3xl rounded-[1.75rem] p-8">
			<span class="eyebrow mb-3">
				<span
					class="h-2 w-2 rounded-full bg-brand-gradient"
					aria-hidden="true"
				></span>
				مأموریت ما
			</span>
			<p class="text-2xl font-bold leading-snug">
				کمک به کسب‌وکارها برای رشد، با ویدیوهایی که می‌فروشند و در خاطر
				می‌مانند.
			</p>
		</div>
	</div>
</section>

<StatsCounter />
<CTA />
