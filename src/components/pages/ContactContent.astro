---
/* Contact page body — form island + direct channels. */
import ContactForm from "@components/ContactForm.tsx"
import GradientBlobs from "@components/GradientBlobs.astro"
import { social, FORMSPREE_ENDPOINT } from "@data/site"
---

<section class="section relative overflow-hidden">
  <GradientBlobs />
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-2">
      {/* Intro + socials */}
      <div class="reveal">
        <span class="eyebrow mb-4">
          <span class="h-2 w-2 rounded-full bg-brand-gradient" aria-hidden="true"></span>
          تماس با ما
        </span>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
          بزنیم به <span class="text-gradient-animated">کار؟</span>
        </h1>
        <p class="mt-4 text-lg leading-9 text-fg-muted">
          از یک ایدهٔ خام تا یک کمپین کامل، هر جای مسیر که هستید بنویسید.
          مشاورهٔ اول رایگان است و حداکثر یک روز کاری بعد جواب می‌دهیم.
        </p>

        <div class="mt-8">
          <h2 class="mb-3 text-sm font-bold uppercase tracking-wider text-fg-muted">راه‌های مستقیم</h2>
          <div class="flex flex-wrap gap-3">
            <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle></svg>
              اینستاگرام
            </a>
            <a href={social.telegram} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M21.9 4.3 2.9 11.6c-1.1.4-1.1 1.6 0 2l4.9 1.5 1.8 5.7c.2.6.9.8 1.4.4l2.7-2.2 4.8 3.5c.6.4 1.4.1 1.6-.6L23.9 5.6c.2-1-.7-1.7-2-1.3z"></path></svg>
              تلگرام
            </a>
            <a href={`mailto:${social.email}`} class="btn-ghost" dir="ltr">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
              {social.email}
            </a>
          </div>
        </div>

        <div class="card mt-10 max-w-md p-6">
          <p class="font-bold">قبل از تماس، این سه چیز را آماده کنید:</p>
          <ul class="mt-3 space-y-2 text-sm leading-7 text-fg-muted">
            <li>۱. هدف ویدیو (فروش، معرفی، دیده‌شدن؟)</li>
            <li>۲. مخاطبی که باید ببیندش</li>
            <li>۳. حدود بودجه و زمانی که در ذهن دارید</li>
          </ul>
          <p class="mt-3 text-sm text-fg-muted">همین‌ها کافی است تا جلسهٔ اول، دو برابر مفیدتر باشد.</p>
        </div>
      </div>

      {/* Form */}
      <div class="reveal glass rounded-[1.75rem] p-6 md:p-8" data-reveal-delay="120">
        <ContactForm client:visible endpoint={FORMSPREE_ENDPOINT} email={social.email} />
      </div>
    </div>
  </div>
</section>
