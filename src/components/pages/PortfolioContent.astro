---
/* Full portfolio page body — filterable video grid + lightbox. */
import SectionHeader from "@components/SectionHeader.astro"
import PortfolioGallery from "@components/PortfolioGallery.tsx"
import CTA from "@components/CTA.astro"
import { getPortfolioItems, entrySlug } from "@lib/blog"

const entries = await getPortfolioItems()
const items = entries.map((e) => ({
  slug: entrySlug(e.id),
  title: e.data.title,
  client: e.data.client,
  category: e.data.category,
  thumbnail: e.data.thumbnail.src,
  thumbnailAlt: e.data.thumbnailAlt,
  previewVideo: e.data.previewVideo,
  videoUrl: e.data.videoUrl,
}))

const filters = [
  { id: "all", label: "همه" },
  { id: "social", label: "شبکهٔ اجتماعی" },
  { id: "teaser", label: "تیزر" },
  { id: "motion", label: "موشن" },
  { id: "brand", label: "فیلم برند" },
]
---

<section class="section">
  <div class="container-x">
    <SectionHeader
      eyebrow="نمونه‌کارها"
      title="کارهایی که به آن‌ها افتخار می‌کنیم"
      subtitle="هر پروژه برای یک هدف مشخص ساخته شده؛ روی هر کدام بزنید و خودتان قضاوت کنید."
    />
    <div class="reveal mt-14" data-reveal-delay="100">
      <PortfolioGallery client:load items={items} filters={filters} />
    </div>
  </div>
</section>
<CTA />
