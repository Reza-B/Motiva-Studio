---
/* =============================================================
   HomeSections — the full homepage body, locale-agnostic.
   Reused by both / (fa) and /en. All child components read the
   active locale from the URL, so nothing needs to be passed in.
   ============================================================= */
import Hero from "@components/Hero.astro"
import Marquee from "@components/Marquee.astro"
import ServicesOverview from "@components/ServicesOverview.astro"
import ProcessTimeline from "@components/ProcessTimeline.astro"
import Pricing from "@components/Pricing.astro"
import StatsCounter from "@components/StatsCounter.astro"
import CTA from "@components/CTA.astro"
import SectionHeader from "@components/SectionHeader.astro"
import Testimonials from "@components/Testimonials.tsx"
import PortfolioGallery from "@components/PortfolioGallery.tsx"
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils"
import { testimonials } from "@data/content"
import { getPortfolioItems, splitEntryId } from "@lib/blog"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const tp = useTranslatedPath(lang)

// Featured portfolio (first 6) for the home grid.
const entries = (await getPortfolioItems(lang)).slice(0, 6)
const items = entries.map((e) => ({
  slug: splitEntryId(e.id).slug,
  title: e.data.title,
  client: e.data.client,
  category: e.data.category,
  thumbnail: e.data.thumbnail.src,
  thumbnailAlt: e.data.thumbnailAlt,
  previewVideo: e.data.previewVideo,
  videoUrl: e.data.videoUrl,
}))

const filters = [
  { id: "all", label: t("portfolio.all") },
  { id: "social", label: lang === "fa" ? "شبکه اجتماعی" : "Social" },
  { id: "teaser", label: lang === "fa" ? "تیزر" : "Teaser" },
  { id: "motion", label: lang === "fa" ? "موشن" : "Motion" },
  { id: "brand", label: lang === "fa" ? "برند" : "Brand" },
]

const tItems = testimonials.map((x) => ({
  name: x.name[lang],
  role: x.role[lang],
  quote: x.quote[lang],
}))
---

<Hero />
<Marquee />
<ServicesOverview compact />

{/* Featured portfolio */}
<section class="section" id="work">
  <div class="container-x">
    <SectionHeader
      eyebrow={t("nav.portfolio")}
      title={t("portfolio.title")}
      subtitle={t("portfolio.subtitle")}
    />
    <div class="mt-14">
      <PortfolioGallery
        client:visible
        items={items}
        filters={filters}
        lang={lang}
        viewLabel={t("portfolio.view")}
      />
    </div>
    <div class="reveal mt-10 text-center">
      <a href={tp("/portfolio")} class="btn-ghost">{t("portfolio.more")}</a>
    </div>
  </div>
</section>

<ProcessTimeline />
<Pricing />

{/* Testimonials */}
<section class="section">
  <div class="container-x">
    <SectionHeader
      eyebrow={t("testimonials.title")}
      title={t("testimonials.title")}
      subtitle={t("testimonials.subtitle")}
    />
    <Testimonials client:visible items={tItems} lang={lang} />
  </div>
</section>

<StatsCounter />
<CTA />
