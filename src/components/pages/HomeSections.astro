---
/* Home page body — section order tells the sales story:
   hook (hero) → trust (industries/stats) → offer (services)
   → proof (portfolio/testimonials) → how (process) → close (CTA). */
import Hero from "@components/Hero.astro"
import Marquee from "@components/Marquee.astro"
import ServicesOverview from "@components/ServicesOverview.astro"
import WhyMotiva from "@components/WhyMotiva.astro"
import StatsCounter from "@components/StatsCounter.astro"
import ProcessTimeline from "@components/ProcessTimeline.astro"
import SectionHeader from "@components/SectionHeader.astro"
import PortfolioGallery from "@components/PortfolioGallery.tsx"
import Testimonials from "@components/Testimonials.tsx"
import CTA from "@components/CTA.astro"
import { getPortfolioItems, entrySlug } from "@lib/blog"
import { testimonials } from "@data/content"

const entries = (await getPortfolioItems()).slice(0, 6)
const items = entries.map((e) => ({
  slug: entrySlug(e.id),
  title: e.data.title,
  client: e.data.client,
  category: e.data.category,
  thumbnail: e.data.thumbnail.src,
  thumbnailAlt: e.data.thumbnailAlt,
  previewVideo: e.data.previewVideo,
  videoUrl: e.data.videoUrl,
}))

const filters = [
  { id: "all", label: "همه" },
  { id: "social", label: "شبکهٔ اجتماعی" },
  { id: "teaser", label: "تیزر" },
  { id: "motion", label: "موشن" },
  { id: "brand", label: "فیلم برند" },
]
---

<Hero />
<Marquee />
<ServicesOverview />
<StatsCounter />

{/* Featured work */}
<section class="section">
  <div class="container-x">
    <SectionHeader
      eyebrow="نمونه‌کارها"
      title="ببینید چه ساخته‌ایم"
      subtitle="به‌جای تعریف، خودِ کارها را تماشا کنید؛ هر کدام برای یک هدف مشخص ساخته شده‌اند."
    />
    <div class="reveal mt-12" data-reveal-delay="100">
      <PortfolioGallery client:visible items={items} filters={filters} />
    </div>
    <div class="reveal mt-10 text-center">
      <a href="/portfolio" class="btn-ghost">همهٔ نمونه‌کارها</a>
    </div>
  </div>
</section>

<WhyMotiva />
<ProcessTimeline />

{/* Social proof */}
<section class="section bg-bg-soft/50">
  <div class="container-x">
    <SectionHeader
      eyebrow="نظر مشتری‌ها"
      title="از زبان کسانی که با ما کار کرده‌اند"
    />
    <div class="reveal mt-12" data-reveal-delay="100">
      <Testimonials client:visible items={testimonials} />
    </div>
  </div>
</section>

<CTA />
