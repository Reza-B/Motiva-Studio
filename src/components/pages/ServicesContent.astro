---
/* Services page body — hero + service list + why + process + pricing. */
import GradientBlobs from "@components/GradientBlobs.astro";
import ServicesOverview from "@components/ServicesOverview.astro";
import WhyMotiva from "@components/WhyMotiva.astro";
import ProcessTimeline from "@components/ProcessTimeline.astro";
import Pricing from "@components/Pricing.astro";
import CTA from "@components/CTA.astro";
---

<section class="section relative overflow-hidden pb-0">
	<GradientBlobs />
	<div class="container-x">
		<div class="reveal max-w-3xl">
			<span class="eyebrow mb-4">
				<span
					class="h-2 w-2 rounded-full bg-brand-gradient"
					aria-hidden="true"
				></span>
				خدمات ما
			</span>
			<h1
				class="text-3xl font-bold tracking-tight leading-10 sm:text-5xl lg:text-6xl"
			>
				دیده شدن برند شما <span class="text-gradient-animated">کار ماست!</span>
			</h1>
			<p class="mt-6 text-xl leading-9 text-fg-muted">
				قبل از انتخاب فرمت، از هدفتان می‌پرسیم: فروش بیشتر؟ معرفی محصول تازه؟
				دیده‌شدن در اینستاگرام؟ بعد فرمتی را پیشنهاد می‌دهیم که سریع‌ترین مسیر
				به آن هدف است.
			</p>
		</div>
	</div>
</section>

<ServicesOverview showHeader={false} />
<WhyMotiva />
<ProcessTimeline />
<Pricing />
<CTA />
