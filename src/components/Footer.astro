---
/* =============================================================
   Footer — brand blurb, nav, social links, newsletter stub.
   ============================================================= */
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
} from "@i18n/utils";
import { social } from "@data/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);
const year = new Date().getFullYear();

const nav = [
	{ href: tp("/services"), label: t("nav.services") },
	{ href: tp("/portfolio"), label: t("nav.portfolio") },
	{ href: tp("/about"), label: t("nav.about") },
	{ href: tp("/blog"), label: t("nav.blog") },
	{ href: tp("/contact"), label: t("nav.contact") },
];
---

<footer class="relative mt-24 border-t border-border bg-bg-soft">
	<div class="container-x grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-4">
		{/* Brand */}
		<div class="lg:col-span-2">
			<a
				href={tp("/")}
				class="flex items-center gap-2.5 font-extrabold"
			>
				<img
					src="/logo.png"
					alt={t("site.name")}
					class="h-9 w-9 rounded-xl object-cover"
				/>
				<span class="text-lg">{t("site.name")}</span>
			</a>
			<p class="mt-4 max-w-sm text-fg-muted">{t("site.description")}</p>
			<div class="mt-6 flex gap-3">
				<a
					href={social.instagram}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Instagram"
					class="grid h-10 w-10 place-items-center rounded-full border border-border transition hover:border-brand-pink hover:text-brand-pink"
				>
					<svg
						viewBox="0 0 24 24"
						class="h-5 w-5"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						><rect
							x="2"
							y="2"
							width="20"
							height="20"
							rx="5"
						></rect><circle
							cx="12"
							cy="12"
							r="4"
						></circle><circle
							cx="17.5"
							cy="6.5"
							r="1"
							fill="currentColor"
						></circle></svg
					>
				</a>
				<a
					href={social.telegram}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Telegram"
					class="grid h-10 w-10 place-items-center rounded-full border border-border transition hover:border-brand-pink hover:text-brand-pink"
				>
					<svg
						viewBox="0 0 24 24"
						class="h-5 w-5"
						fill="currentColor"
						><path
							d="M21.9 4.3 2.9 11.6c-1.1.4-1.1 1.6 0 2l4.9 1.5 1.8 5.7c.2.6.9.8 1.4.4l2.7-2.2 4.8 3.5c.6.4 1.4.1 1.6-.6L23.9 5.6c.2-1-.7-1.7-2-1.3z"
						></path></svg
					>
				</a>
				<a
					href={`mailto:${social.email}`}
					aria-label="Email"
					class="grid h-10 w-10 place-items-center rounded-full border border-border transition hover:border-brand-pink hover:text-brand-pink"
				>
					<svg
						viewBox="0 0 24 24"
						class="h-5 w-5"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						><rect
							x="3"
							y="5"
							width="18"
							height="14"
							rx="2"
						></rect><path d="m3 7 9 6 9-6"></path></svg
					>
				</a>
			</div>
		</div>

		{/* Nav */}
		<div>
			<h2 class="mb-4 text-sm font-bold uppercase tracking-wider text-fg-muted">
				{t("footer.nav")}
			</h2>
			<ul class="space-y-2">
				{
					nav.map((item) => (
						<li>
							<a
								href={item.href}
								class="text-fg-muted transition hover:text-brand-pink"
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>

		{/* Newsletter (static stub — wire to Formspree/Buttondown if desired) */}
		<div>
			<h2 class="mb-4 text-sm font-bold uppercase tracking-wider text-fg-muted">
				{t("footer.newsletter")}
			</h2>
			<p class="mb-4 text-sm text-fg-muted">{t("footer.newsletter.desc")}</p>
			<form
				class="flex gap-2"
				onsubmit="return false"
			>
				<input
					type="email"
					required
					placeholder={t("contact.email")}
					aria-label={t("contact.email")}
					class="min-w-0 flex-1 rounded-full border border-border bg-surface px-4 py-2 text-sm outline-none focus:border-brand-pink"
				/>
				<button
					type="submit"
					class="btn-primary !px-4 !py-2 text-sm"
					aria-label={t("footer.newsletter")}
					>→</button
				>
			</form>
		</div>
	</div>

	<div
		class="container-x flex flex-col items-center justify-between gap-2 border-t border-border py-6 text-sm text-fg-muted md:flex-row"
	>
		<p>© {year} {t("site.name")}. {t("footer.rights")}</p>
		<p>{t("footer.madeWith")}</p>
	</div>
</footer>
