---
/* =============================================================
   Footer — brand summary, sitemap, contact channels.
   (فرم خبرنامهٔ تزئینی قبلی حذف شد — چیزی که کار نمی‌کند
   نباید در سایت باشد.)
   ============================================================= */
import { social } from "@data/site"

const year = new Intl.NumberFormat("fa-IR", { useGrouping: false }).format(
  new Date().getFullYear(),
)

const pages = [
  { href: "/", label: "خانه" },
  { href: "/services", label: "خدمات" },
  { href: "/portfolio", label: "نمونه‌کارها" },
  { href: "/blog", label: "بلاگ" },
  { href: "/about", label: "درباره ما" },
  { href: "/contact", label: "تماس با ما" },
]

const services = [
  { href: "/services#social", label: "ویدیوی شبکه‌های اجتماعی" },
  { href: "/services#teaser", label: "تیزر تبلیغاتی" },
  { href: "/services#motion", label: "موشن گرافیک" },
  { href: "/services#brand", label: "فیلم برند" },
]
---

<footer class="relative mt-24 border-t border-border bg-bg-soft">
  {/* Gradient hairline on top of the footer. */}
  <div class="absolute inset-x-0 top-0 h-px bg-brand-gradient opacity-60" aria-hidden="true"></div>

  <div class="container-x grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-4">
    {/* Brand */}
    <div class="lg:col-span-2">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.png" alt="لوگوی استودیو موتیوا" class="h-11 w-11 rounded-xl object-contain" width="44" height="44" />
        <span class="text-xl font-extrabold">استودیو موتیوا</span>
      </a>
      <p class="mt-5 max-w-md leading-8 text-fg-muted">
        ما برای برندها ویدیو می‌سازیم؛ از ریلزی که دست مخاطب را روی صفحه نگه
        می‌دارد تا تیزری که محصولتان را به فروش می‌رساند. اگر قرار است یک بار
        دیده شوید، بگذارید درست دیده شوید.
      </p>
      <div class="mt-6 flex gap-3">
        <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="اینستاگرام موتیوا" class="grid h-11 w-11 place-items-center rounded-full border border-border text-fg-muted transition hover:border-brand-pink hover:text-brand-pink">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle></svg>
        </a>
        <a href={social.telegram} target="_blank" rel="noopener noreferrer" aria-label="تلگرام موتیوا" class="grid h-11 w-11 place-items-center rounded-full border border-border text-fg-muted transition hover:border-brand-pink hover:text-brand-pink">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M21.9 4.3 2.9 11.6c-1.1.4-1.1 1.6 0 2l4.9 1.5 1.8 5.7c.2.6.9.8 1.4.4l2.7-2.2 4.8 3.5c.6.4 1.4.1 1.6-.6L23.9 5.6c.2-1-.7-1.7-2-1.3z"></path></svg>
        </a>
        <a href={`mailto:${social.email}`} aria-label="ایمیل موتیوا" class="grid h-11 w-11 place-items-center rounded-full border border-border text-fg-muted transition hover:border-brand-pink hover:text-brand-pink">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
        </a>
      </div>
    </div>

    {/* Pages */}
    <nav aria-label="لینک‌های فوتر">
      <h2 class="mb-4 text-sm font-bold uppercase tracking-wider text-fg-muted">صفحه‌ها</h2>
      <ul class="space-y-2.5">
        {pages.map((p) => (
          <li><a href={p.href} class="text-fg-muted transition hover:text-fg">{p.label}</a></li>
        ))}
      </ul>
    </nav>

    {/* Services + contact */}
    <div>
      <h2 class="mb-4 text-sm font-bold uppercase tracking-wider text-fg-muted">خدمات</h2>
      <ul class="space-y-2.5">
        {services.map((s) => (
          <li><a href={s.href} class="text-fg-muted transition hover:text-fg">{s.label}</a></li>
        ))}
      </ul>
      <a href={`mailto:${social.email}`} class="mt-6 inline-block font-medium text-fg transition hover:text-brand-pink" dir="ltr">
        {social.email}
      </a>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-6 text-sm text-fg-muted sm:flex-row">
      <p>© {year} استودیو موتیوا — همهٔ حقوق محفوظ است.</p>
      <p>ساخته‌شده با عشق به قاب‌های خوب 🎬</p>
    </div>
  </div>
</footer>
