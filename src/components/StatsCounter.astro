---
/* Stats band — animated count-up numbers ([data-counter]). */
import { stats } from "@data/site"
---

<section class="relative overflow-hidden border-y border-border bg-bg-soft/60 py-14">
  <div class="pointer-events-none absolute inset-0 bg-hero-glow opacity-60" aria-hidden="true"></div>
  <div class="container-x relative grid grid-cols-2 gap-8 text-center lg:grid-cols-4">
    {
      stats.map((s, i) => (
        <div class="reveal" data-reveal-delay={i * 80}>
          <p class="text-4xl font-extrabold tracking-tight text-gradient sm:text-5xl" dir="ltr">
            <span data-counter={s.value}>۰</span>{s.suffix}
          </p>
          <p class="mt-2 text-sm text-fg-muted sm:text-base">{s.label}</p>
        </div>
      ))
    }
  </div>
</section>
