---
/* =============================================================
   StatsCounter — animated counters (see animations.ts:initCounters
   which drives [data-counter] on scroll). Numbers are localized
   at runtime (fa-IR vs en-US).
   ============================================================= */
import { getLangFromUrl, useTranslations } from "@i18n/utils"
import { stats } from "@data/site"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="section relative overflow-hidden">
  <div class="container-x">
    <div class="reveal grid grid-cols-2 gap-6 rounded-3xl border border-border bg-surface p-8 md:grid-cols-4 md:p-12">
      {
        stats.map((s) => (
          <div class="text-center">
            <div dir="ltr" class="flex items-baseline justify-center text-4xl font-extrabold text-gradient md:text-5xl">
              <span data-counter={s.value}>0</span>
              <span>{s.suffix}</span>
            </div>
            <p class="mt-2 text-sm text-fg-muted">{t(s.key)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
