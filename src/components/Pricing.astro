---
/* Pricing — three project-based packages. */
import SectionHeader from "@components/SectionHeader.astro"
import { pricing } from "@data/content"
---

<section class="section bg-bg-soft/50">
  <div class="container-x">
    <SectionHeader
      eyebrow="پکیج‌ها"
      title="هر بودجه‌ای، یک راه شروع دارد"
      subtitle="قیمت نهایی به ابعاد پروژه بستگی دارد؛ بعد از یک جلسهٔ کوتاه، عدد دقیق و شفاف می‌دهیم — بدون هزینهٔ پنهان."
    />

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        pricing.map((plan, i) => (
          <article
            class:list={[
              "reveal relative flex flex-col rounded-[1.75rem] p-8",
              plan.popular
                ? "border-2 border-transparent [background:linear-gradient(rgb(var(--surface)),rgb(var(--surface)))_padding-box,linear-gradient(120deg,#F7861E,#D81E77)_border-box] shadow-glow lg:-translate-y-3"
                : "card",
            ]}
            data-reveal-delay={i * 100}
          >
            {plan.popular && (
              <span class="absolute -top-4 right-8 rounded-full bg-brand-gradient px-4 py-1 text-xs font-bold text-white shadow-glow">
                محبوب‌ترین انتخاب
              </span>
            )}
            <h3 class="text-2xl font-extrabold">{plan.name}</h3>
            <p class="mt-1 text-sm text-fg-muted">{plan.tagline}</p>
            <p class="mt-6 text-lg font-bold text-gradient">{plan.price}</p>
            <ul class="mt-6 flex-1 space-y-3 border-t border-border pt-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 leading-7 text-fg-muted">
                  <svg viewBox="0 0 24 24" class="mt-1.5 h-4 w-4 shrink-0 text-brand-pink" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m5 13 4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class:list={[plan.popular ? "btn-primary" : "btn-ghost", "mt-8 w-full"]}>
              درخواست مشاورهٔ رایگان
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
