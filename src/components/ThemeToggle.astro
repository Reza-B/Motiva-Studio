---
/* =============================================================
   ThemeToggle — light/dark switch.
   Persists to localStorage; animates the icon swap.
   Ships one tiny inline script (no framework needed).
   ============================================================= */
import { getLangFromUrl, useTranslations } from "@i18n/utils"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<button
  id="theme-toggle"
  type="button"
  class="group relative grid h-10 w-10 place-items-center rounded-full border border-border bg-surface/60 backdrop-blur transition hover:border-brand-pink"
  aria-label={t("theme.toggle")}
  title={t("theme.toggle")}
>
  {/* Sun (shown in dark mode) */}
  <svg
    class="absolute h-5 w-5 rotate-90 scale-0 text-brand-orange transition-all duration-500 dark:rotate-0 dark:scale-100"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <path
      d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"
      stroke-linecap="round"></path>
  </svg>
  {/* Moon (shown in light mode) */}
  <svg
    class="absolute h-5 w-5 rotate-0 scale-100 text-brand-pink transition-all duration-500 dark:-rotate-90 dark:scale-0"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<script>
  // Delegated so it keeps working after View Transition swaps.
  function setup() {
    const btn = document.getElementById("theme-toggle")
    if (!btn || btn.dataset.bound) return
    btn.dataset.bound = "true"
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark")
      try {
        localStorage.setItem("theme", isDark ? "dark" : "light")
      } catch (e) {}
    })
  }
  document.addEventListener("astro:page-load", setup)
</script>
