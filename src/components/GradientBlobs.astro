---
/* =============================================================
   Decorative animated gradient blobs — sits behind hero/sections.
   Pure CSS animation (cheap), hidden from assistive tech.
   ============================================================= */
interface Props {
  class?: string
}
const { class: className = "" } = Astro.props
---

<div class:list={["pointer-events-none absolute inset-0 -z-10 overflow-hidden", className]} aria-hidden="true">
  <div class="absolute -top-32 left-[8%] h-[420px] w-[420px] animate-float rounded-full bg-[#F7861E]/15 blur-[110px]"></div>
  <div class="absolute top-1/3 right-[4%] h-[460px] w-[460px] animate-float rounded-full bg-[#D81E77]/15 blur-[120px]" style="animation-delay:-3s"></div>
  <div class="absolute -bottom-40 left-1/3 h-[380px] w-[380px] animate-float rounded-full bg-[#7C3AED]/12 blur-[110px]" style="animation-delay:-6s"></div>
</div>
