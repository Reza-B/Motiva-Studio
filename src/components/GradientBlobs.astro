---
/* =============================================================
   GradientBlobs — animated brand-colored mesh blobs used as a
   decorative background. Pure CSS animation (float + blur), so
   it costs no JS and is automatically calmed by the global
   prefers-reduced-motion rule in global.css.
   ============================================================= */
interface Props {
  class?: string
}
const { class: className = "" } = Astro.props
---

<div
  class:list={[
    "pointer-events-none absolute inset-0 -z-10 overflow-hidden",
    className,
  ]}
  aria-hidden="true"
>
  <div
    class="absolute -top-24 start-[10%] h-72 w-72 rounded-full bg-brand-orange/30 blur-3xl animate-float"
    style="animation-delay: -2s"
  >
  </div>
  <div
    class="absolute top-1/3 end-[5%] h-80 w-80 rounded-full bg-brand-pink/30 blur-3xl animate-float"
    style="animation-delay: -5s"
  >
  </div>
  <div
    class="absolute bottom-0 start-1/3 h-72 w-72 rounded-full bg-brand-orange/20 blur-3xl animate-float"
  >
  </div>
</div>
