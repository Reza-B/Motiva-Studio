---
/* =============================================================
   Process timeline — 5 steps on a vertical spine.
   The spine "draws" itself while you scroll
   ([data-timeline-progress] → initTimelineDraw).
   ============================================================= */
import SectionHeader from "@components/SectionHeader.astro"
import { processSteps } from "@data/content"
---

<section class="section">
  <div class="container-x">
    <SectionHeader
      eyebrow="مسیر پروژه"
      title="از ایده تا انتشار، در ۵ قدم"
      subtitle="هیچ مرحله‌ای در تاریکی نمی‌ماند؛ همیشه می‌دانید پروژه کجاست و قدم بعدی چیست."
    />

    <div class="relative mx-auto mt-16 max-w-3xl">
      {/* Spine + animated progress */}
      <div class="absolute inset-y-0 right-6 w-px bg-border sm:right-8" aria-hidden="true">
        <div data-timeline-progress class="h-full w-full origin-top scale-y-0 bg-brand-gradient"></div>
      </div>

      <ol class="space-y-10">
        {
          processSteps.map((s, i) => (
            <li class="reveal relative pr-20 sm:pr-24" data-reveal-delay={i * 80}>
              <span class="absolute right-0 top-0 grid h-12 w-12 place-items-center rounded-full bg-brand-gradient text-lg font-extrabold text-white shadow-glow sm:h-16 sm:w-16 sm:text-xl">
                {s.step}
              </span>
              <h3 class="text-xl font-bold">{s.title}</h3>
              <p class="mt-2 leading-8 text-fg-muted">{s.description}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
