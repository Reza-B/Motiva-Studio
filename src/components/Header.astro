---
/* =============================================================
   Header — fixed glass bar that condenses after scrolling.
   The `group` class + [data-scrolled] drive the condensed style
   (see initHeader in lib/animations.ts).
   ============================================================= */
import MobileMenu from "@components/MobileMenu.tsx"

const nav = [
  { href: "/", label: "خانه" },
  { href: "/services", label: "خدمات" },
  { href: "/portfolio", label: "نمونه‌کارها" },
  { href: "/blog", label: "بلاگ" },
  { href: "/about", label: "درباره ما" },
]

const path = Astro.url.pathname.replace(/\/$/, "") || "/"
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href)
---

<header
  data-header
  class="group fixed inset-x-0 top-0 z-50 transition-all duration-300
    data-[scrolled]:bg-bg/80 data-[scrolled]:shadow-soft data-[scrolled]:backdrop-blur-xl"
>
  <div
    class="container-x flex items-center justify-between py-5 transition-all duration-300 group-data-[scrolled]:py-3"
  >
    {/* Logo */}
    <a href="/" class="flex items-center gap-3" aria-label="استودیو موتیوا — صفحهٔ اصلی">
      <img src="/logo.png" alt="لوگوی استودیو موتیوا" class="h-10 w-10 rounded-xl object-contain" width="40" height="40" />
      <span class="text-lg font-extrabold tracking-tight">استودیو موتیوا</span>
    </a>

    {/* Desktop nav */}
    <nav class="hidden items-center gap-1 lg:flex" aria-label="منوی اصلی">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "relative rounded-full px-4 py-2 text-sm font-medium transition-colors",
              isActive(item.href)
                ? "text-fg"
                : "text-fg-muted hover:text-fg",
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span class="absolute inset-x-4 -bottom-0.5 h-0.5 rounded-full bg-brand-gradient" aria-hidden="true" />
            )}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="/contact" class="btn-primary hidden !px-6 !py-2.5 text-sm lg:inline-flex">
        شروع پروژه
      </a>
      <div class="lg:hidden">
        <MobileMenu client:load links={[...nav, { href: "/contact", label: "تماس با ما" }]} />
      </div>
    </div>
  </div>
</header>

{/* Spacer so content doesn't hide behind the fixed header. */}
<div class="h-20" aria-hidden="true"></div>
