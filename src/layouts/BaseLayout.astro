---
/* =============================================================
   BaseLayout — shared page shell.
   RTL Persian, fixed cinematic dark theme, view transitions,
   Lenis smooth scrolling and the GSAP animation engine.
   ============================================================= */
import { ClientRouter } from "astro:transitions"
import SEO from "@components/SEO.astro"
import Header from "@components/Header.astro"
import Footer from "@components/Footer.astro"
import "@/styles/global.css"

interface Props {
  title: string
  description: string
  keywords?: string
  type?: "website" | "article"
  image?: string
  noindex?: boolean
  jsonLd?: object[]
}

const props = Astro.props
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0F0B14" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="alternate" type="application/rss+xml" title="بلاگ استودیو موتیوا" href="/rss.xml" />

    <SEO {...props} />
    <ClientRouter />
  </head>

  <body class="min-h-screen overflow-x-clip">
    <a
      href="#main"
      class="fixed right-4 top-4 z-[100] -translate-y-24 rounded-full bg-brand-gradient px-5 py-2 text-sm font-bold text-white transition focus:translate-y-0"
    >
      پرش به محتوا
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <script>
      import { initLenis } from "@lib/lenis"
      import { initAllAnimations } from "@lib/animations"

      // Runs on first load and after every view transition.
      document.addEventListener("astro:page-load", () => {
        initLenis()
        initAllAnimations()
      })
    </script>
  </body>
</html>
