---
/* =============================================================
   BaseLayout — the HTML shell for every page.
   - Sets <html lang dir> based on the active locale.
   - Injects SEO meta + JSON-LD.
   - Boots the theme (before paint, no FOUC) + Lenis + GSAP.
   - Enables Astro View Transitions (<ClientRouter />).
   ============================================================= */
import "../styles/global.css"
import { ClientRouter } from "astro:transitions"
import SEO from "@components/SEO.astro"
import Header from "@components/Header.astro"
import Footer from "@components/Footer.astro"
import { getLangFromUrl } from "@i18n/utils"
import { dir } from "@i18n/ui"
import { organizationSchema, localBusinessSchema } from "@lib/structuredData"

interface Props {
  title: string
  description: string
  keywords?: string
  image?: string
  type?: "website" | "article"
  jsonLd?: Record<string, unknown>[]
  noindex?: boolean
}

const lang = getLangFromUrl(Astro.url)
const { title, description, keywords, image, type, jsonLd = [], noindex } =
  Astro.props

// Every page carries Organization + LocalBusiness structured data.
const baseSchema = [organizationSchema(lang), localBusinessSchema(lang)]
---

<!doctype html>
<html lang={lang} dir={dir[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#D81E77" />

    <SEO
      title={title}
      description={description}
      keywords={keywords}
      lang={lang}
      image={image}
      type={type}
      jsonLd={[...baseSchema, ...jsonLd]}
      noindex={noindex}
    />

    {/* RSS discovery */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Motiva Studio Blog"
      href="/rss.xml"
    />

    {/* Theme boot: runs before paint to prevent a flash of the wrong theme. */}
    <script is:inline>
      ;(() => {
        try {
          const stored = localStorage.getItem("theme")
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches
          const theme = stored || (prefersDark ? "dark" : "light")
          document.documentElement.classList.toggle("dark", theme === "dark")
        } catch (e) {}
      })()
    </script>

    {/* Keep the theme across View Transitions swaps (before-swap fires early). */}
    <script is:inline>
      document.addEventListener("astro:before-swap", (ev) => {
        const isDark = document.documentElement.classList.contains("dark")
        ev.newDocument.documentElement.classList.toggle("dark", isDark)
      })
    </script>

    <ClientRouter />
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:z-[100] focus:top-4 focus:start-4 focus:rounded-full focus:bg-brand-gradient focus:px-5 focus:py-2 focus:text-white"
    >
      {lang === "fa" ? "پرش به محتوا" : "Skip to content"}
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    {/* Animations + smooth scroll. Loaded as a module; re-runs after each
        View Transition navigation via astro:page-load. */}
    <script>
      import { initLenis } from "@lib/lenis"
      import { initAllAnimations } from "@lib/animations"

      function boot() {
        initLenis()
        initAllAnimations()
      }
      // Fires on first load AND after every View Transition navigation.
      document.addEventListener("astro:page-load", boot)
    </script>
  </body>
</html>
