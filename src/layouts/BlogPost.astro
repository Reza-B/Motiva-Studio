---
/* =============================================================
   Blog post layout — editorial reading experience:
   hero cover, meta bar, comfy prose measure, share links,
   and "more posts" at the end.
   ============================================================= */
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import BaseLayout from "@layouts/BaseLayout.astro"
import CTA from "@components/CTA.astro"
import { getBlogPosts, entrySlug, readingMinutes } from "@lib/blog"
import { SITE_URL } from "@data/site"

interface Props {
  entry: CollectionEntry<"blog">
  readingTime: number
}

const { entry, readingTime } = Astro.props
const { title, description, pubDate, updatedDate, author, cover, coverAlt, category, tags } = entry.data

const dateFmt = new Intl.DateTimeFormat("fa-IR", { year: "numeric", month: "long", day: "numeric" })
const postUrl = `${SITE_URL}/blog/${entrySlug(entry.id)}`

// Share URLs (built via concatenation on purpose — keeps template clean).
const shareQuery = `?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(title)}`
const telegramShare = "https://t.me" + "/share/url" + shareQuery
const twitterShare = "https://twitter.com" + "/intent/tweet" + shareQuery

// Up to 3 other posts, same category first.
const all = (await getBlogPosts()).filter((p) => p.id !== entry.id)
const more = [
  ...all.filter((p) => p.data.category === category),
  ...all.filter((p) => p.data.category !== category),
].slice(0, 3)
---

<BaseLayout
  title={`${title} — بلاگ استودیو موتیوا`}
  description={description}
  ogImage={cover?.src}
  article={{ pubDate, updatedDate, author, tags }}
>
  <article class="section">
    <div class="container-x">
      {/* Header */}
      <header class="mx-auto max-w-3xl text-center">
        <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-fg-muted">
          <a href="/blog" class="rounded-full bg-brand-gradient px-3.5 py-1 text-xs font-bold text-white transition hover:opacity-90">{category}</a>
          <time datetime={pubDate.toISOString()}>{dateFmt.format(pubDate)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} دقیقه مطالعه</span>
        </div>
        <h1 class="mt-5 text-3xl font-extrabold leading-snug tracking-tight sm:text-4xl lg:text-5xl lg:leading-[1.3]">
          {title}
        </h1>
        <p class="mt-5 text-lg leading-9 text-fg-muted">{description}</p>
        <p class="mt-4 text-sm text-fg-muted">نوشتهٔ {author}</p>
      </header>

      {/* Cover */}
      {
        cover && (
          <figure class="reveal mx-auto mt-10 max-w-4xl overflow-hidden rounded-[2rem] border border-border shadow-soft">
            <Image
              src={cover}
              alt={coverAlt ?? title}
              widths={[640, 960, 1280]}
              sizes="(max-width: 960px) 100vw, 900px"
              class="w-full object-cover"
              loading="eager"
            />
          </figure>
        )
      }

      {/* Body */}
      <div class="prose-motiva mx-auto mt-12 max-w-3xl">
        <slot />
      </div>

      {/* Footer meta */}
      <footer class="mx-auto mt-12 max-w-3xl border-t border-border pt-8">
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full border border-border bg-surface px-3.5 py-1.5 text-xs font-medium text-fg-muted">#{tag}</span>
              ))}
            </div>
          )
        }
        {
          updatedDate && (
            <p class="mt-4 text-sm text-fg-muted">آخرین به‌روزرسانی: {dateFmt.format(updatedDate)}</p>
          )
        }
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="text-sm font-bold">به اشتراک بگذارید:</span>
          <a
            href={telegramShare}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-border px-4 py-2 text-sm text-fg-muted transition hover:border-brand-pink hover:text-fg"
          >تلگرام</a>
          <a
            href={twitterShare}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-border px-4 py-2 text-sm text-fg-muted transition hover:border-brand-pink hover:text-fg"
          >ایکس (توییتر)</a>
          <button
            type="button"
            data-copy-link={postUrl}
            class="rounded-full border border-border px-4 py-2 text-sm text-fg-muted transition hover:border-brand-pink hover:text-fg"
          >کپی لینک</button>
        </div>
      </footer>

      {/* More posts */}
      {
        more.length > 0 && (
          <aside class="mx-auto mt-16 max-w-4xl">
            <h2 class="text-xl font-extrabold">خواندنی‌های بیشتر</h2>
            <div class="mt-6 grid gap-5 sm:grid-cols-3">
              {more.map((p) => (
                <a href={`/blog/${entrySlug(p.id)}`} class="card card-hover group flex flex-col !p-5">
                  <span class="text-xs font-bold text-brand-pink">{p.data.category}</span>
                  <span class="mt-2 flex-1 font-bold leading-relaxed transition group-hover:text-brand-pink">{p.data.title}</span>
                  <span class="mt-3 text-xs text-fg-muted">{readingMinutes(p)} دقیقه مطالعه</span>
                </a>
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </article>

  <CTA />
</BaseLayout>

<script>
  // "Copy link" button — re-bound after every view transition.
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLButtonElement>("[data-copy-link]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copyLink ?? "")
          const prev = btn.textContent
          btn.textContent = "کپی شد ✓"
          setTimeout(() => (btn.textContent = prev), 1800)
        } catch {
          /* clipboard unavailable — ignore */
        }
      })
    })
  })
</script>
