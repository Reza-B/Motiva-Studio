---
import BaseLayout from "@layouts/BaseLayout.astro"
import BlogList from "@components/pages/BlogList.astro"
import { getLangFromUrl, useTranslations } from "@i18n/utils"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<BaseLayout title={t("seo.blog.title")} description={t("seo.blog.desc")} keywords={t("seo.blog.keywords")}>
  <BlogList />
</BaseLayout>
