---
import BaseLayout from "@layouts/BaseLayout.astro"
import GradientBlobs from "@components/GradientBlobs.astro"
---

<BaseLayout
  title="404 — استودیو موتیوا"
  description="صفحه‌ای که دنبالش بودید پیدا نشد."
  noindex
>
  <section class="grain relative flex min-h-[70vh] items-center overflow-hidden">
    <GradientBlobs />
    <div class="container-x text-center">
      <p class="text-8xl font-extrabold text-gradient-animated">404</p>
      <h1 class="mt-4 text-3xl font-bold">این صحنه از فیلمنامه حذف شده!</h1>
      <p class="mt-2 text-fg-muted">صفحه‌ای که دنبالش بودید یا جابه‌جا شده یا از اول وجود نداشته.</p>
      <a href="/" class="btn-primary mt-8">برگشت به خانه</a>
    </div>
  </section>
</BaseLayout>
