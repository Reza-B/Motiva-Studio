---
import BaseLayout from "@layouts/BaseLayout.astro"
import PortfolioContent from "@components/pages/PortfolioContent.astro"
import { getLangFromUrl, useTranslations } from "@i18n/utils"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<BaseLayout title={t("seo.portfolio.title")} description={t("seo.portfolio.desc")} keywords={t("seo.portfolio.keywords")}>
  <PortfolioContent />
</BaseLayout>
