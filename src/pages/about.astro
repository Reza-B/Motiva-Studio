---
import BaseLayout from "@layouts/BaseLayout.astro"
import AboutContent from "@components/pages/AboutContent.astro"
import { getLangFromUrl, useTranslations } from "@i18n/utils"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<BaseLayout title={t("seo.about.title")} description={t("seo.about.desc")} keywords={t("seo.about.keywords")}>
  <AboutContent />
</BaseLayout>
