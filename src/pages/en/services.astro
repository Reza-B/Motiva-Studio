---
import BaseLayout from "@layouts/BaseLayout.astro"
import ServicesContent from "@components/pages/ServicesContent.astro"
import { getLangFromUrl, useTranslations } from "@i18n/utils"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<BaseLayout title={t("seo.services.title")} description={t("seo.services.desc")} keywords={t("seo.services.keywords")}>
  <ServicesContent />
</BaseLayout>
